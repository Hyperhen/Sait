# Скопіюйте цей файл як `.env` і заповніть значення. Не комітьте `.env`.

# Порт HTTP-сервера (за замовчуванням 3000)
# PORT=3000

# Режим: на production обов’язковий надійний SESSION_SECRET (див. нижче).
# NODE_ENV=development
# NODE_ENV=production

# Секрет підпису cookie сесії (адмін-панель). У production обов’язковий, довгий випадковий рядок.
# Згенерувати: openssl rand -base64 48
SESSION_SECRET=

# Пароль для входу в приховану адмін-панель (ті самі символи, що вводите у формі «Пароль»).
# Зберігайте лише тут або в змінних середовища на сервері, не в git.
CLUB_ADMIN_PASSWORD=

# Якщо задано — новини/дні народження/реєстрації в MongoDB (рекомендовано для Vercel замість файлів у /var/task).
MONGODB_URI=

# Одноразовий імпорт з data/*.json і registrations.json: npm run migrate:mongo

# На production за замовчуванням увімкнено trust proxy (HTTPS за nginx/Vercel). Вимкніть лише якщо Node слухає TLS без проксі:
# TRUST_PROXY=0
# Або явно увімкнути в dev як за nginx:
# TRUST_PROXY=1

# Без MONGODB_URI — дані йдуть у JSON-файли (локально або задайте writable шлях):
# DATA_DIR=./data
# REGISTRATIONS_FILE=./registrations.json

# Telegram: нові заявки з форми вступу
# Створіть бота через @BotFather, отримайте токен.
TELEGRAM_TOKEN=
# Chat ID (канал, група або особистий чат). Для груп використовуйте від'ємний ID за потреби.
TELEGRAM_CHAT_ID=

# Email через Gmail (або інший SMTP — змініть SMTP_SERVICE)
# Для Gmail використовуйте "пароль додатку", не звичайний пароль облікового запису.
SMTP_SERVICE=gmail
SMTP_USER=
SMTP_PASS=

# Від кого і кому відправляти листи з реєстрацій
MAIL_FROM=
MAIL_TO=

# Альтернативні імена змінних (підтримуються в коді):
# GMAIL_USER=   — те саме, що SMTP_USER
# GMAIL_APP_PASSWORD= — те саме, що SMTP_PASS
